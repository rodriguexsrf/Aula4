@model Aula4.Models.Local

@{
    ViewData["Title"] = "Delete";
}

<h1>Excluir Local</h1>

<h3>Tem certeza que deseja excluir este local?</h3>
<div>
    <h4>Local</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Nome do Local
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        
        <dt class="col-sm-2">
            Faixa Etária Recomendada
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FaixaEtariaRecomendada) anos
        </dd>
        
        <dt class="col-sm-2">
            Endereço
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Endereco)
        </dd>
        
        <dt class="col-sm-2">
            Tipo de Local
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TipoLocal)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        @Html.AntiForgeryToken()
        <input type="submit" value="Excluir" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar para Lista</a>
    </form>
</div>
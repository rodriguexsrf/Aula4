@model Aula4.Models.Local

@{
    ViewData["Title"] = "Create";
}

<h1>Cadastrar Local</h1>

<h4>Local</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Nome" class="control-label">Nome do Local</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="FaixaEtariaRecomendada" class="control-label">Faixa Etária Recomendada (anos)</label>
                <input asp-for="FaixaEtariaRecomendada" class="form-control" />
                <span asp-validation-for="FaixaEtariaRecomendada" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Endereco" class="control-label">Endereço</label>
                <input asp-for="Endereco" class="form-control" />
                <span asp-validation-for="Endereco" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TipoLocal" class="control-label">Tipo de Local</label>
                <input asp-for="TipoLocal" class="form-control" placeholder="Ex: Parque, Cinema, Museu, Restaurante..." />
                <span asp-validation-for="TipoLocal" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Cadastrar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar para Lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
